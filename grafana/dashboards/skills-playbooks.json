{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "NexusSoc PostgreSQL",
      "description": "NexusSoc ai_soc_results database",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",     "version": "10.0.0" },
    { "type": "datasource", "id": "postgres",   "name": "PostgreSQL",  "version": "1.0.0"  },
    { "type": "panel",      "id": "stat",       "name": "Stat",        "version": ""       },
    { "type": "panel",      "id": "timeseries", "name": "Time series", "version": ""       },
    { "type": "panel",      "id": "bargauge",   "name": "Bar gauge",   "version": ""       },
    { "type": "panel",      "id": "table",      "name": "Table",       "version": ""       }
  ],
  "annotations": { "list": [] },
  "description": "NexusSoc — EMA skill learning evolution, playbook execution rates",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nexussoc", "skills", "playbooks"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NexusSoc — Skills & Playbooks",
  "uid": "nexussoc-skills-v1",
  "version": 1,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Skills Learned",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "cyan" } } },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COUNT(*) AS value FROM soc_skills", "format": "table", "refId": "A" }]
    },
    {
      "id": 2, "type": "stat", "title": "Avg Skill Confidence",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.72 }, { "color": "green", "value": 0.85 }] }
        }
      },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT AVG(confidence_score) AS value FROM soc_skills", "format": "table", "refId": "A" }]
    },
    {
      "id": 3, "type": "stat", "title": "Total Skill Uses",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT SUM(usage_count) AS value FROM soc_skills", "format": "table", "refId": "A" }]
    },
    {
      "id": 4, "type": "stat", "title": "Skill Success Rate",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.6 }, { "color": "green", "value": 0.8 }] }
        }
      },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT CASE WHEN SUM(usage_count) = 0 THEN 0 ELSE SUM(success_count)::float / SUM(usage_count) END AS value FROM soc_skills", "format": "table", "refId": "A" }]
    },
    {
      "id": 5, "type": "stat", "title": "Playbook Executions",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } } },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COUNT(*) AS value FROM soc_playbook_executions", "format": "table", "refId": "A" }]
    },
    {
      "id": 6, "type": "stat", "title": "Active Playbooks",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COUNT(*) AS value FROM soc_playbooks WHERE enabled = true", "format": "table", "refId": "A" }]
    },
    {
      "id": 7, "type": "timeseries", "title": "Skill Confidence Evolution (EMA α=0.15)",
      "gridPos": { "x": 0, "y": 4, "w": 14, "h": 9 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 8, "gradientMode": "opacity", "showPoints": "auto" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Avg Skill Confidence" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "cyan"   } }] },
          { "matcher": { "id": "byName", "options": "Best Skill" },           "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green"  } }] },
          { "matcher": { "id": "byName", "options": "Weakest Skill" },        "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT\n  date_trunc('hour', updated_at) AS time,\n  AVG(confidence_score) AS \"Avg Skill Confidence\",\n  MAX(confidence_score) AS \"Best Skill\",\n  MIN(confidence_score) AS \"Weakest Skill\"\nFROM soc_skills\nWHERE updated_at BETWEEN $__timeFrom() AND $__timeTo()\nGROUP BY 1 ORDER BY 1",
        "format": "time_series", "refId": "A"
      }]
    },
    {
      "id": 8, "type": "timeseries", "title": "Playbook Executions Over Time",
      "gridPos": { "x": 14, "y": 4, "w": 10, "h": 9 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "lineWidth": 0, "fillOpacity": 80, "drawStyle": "bars", "barAlignment": 0 }
        }
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT date_trunc('hour', executed_at) AS time, COUNT(*) AS \"Executions\"\nFROM soc_playbook_executions\nWHERE executed_at BETWEEN $__timeFrom() AND $__timeTo()\nGROUP BY 1 ORDER BY 1",
        "format": "time_series", "refId": "A"
      }]
    },
    {
      "id": 9, "type": "bargauge", "title": "Top Skills by Usage Count",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 9 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }] }
        }
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT skill_name AS metric, usage_count AS value FROM soc_skills ORDER BY usage_count DESC LIMIT 12",
        "format": "table", "refId": "A"
      }]
    },
    {
      "id": 10, "type": "bargauge", "title": "Playbook Execution Counts",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 9 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlPu" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "purple", "value": 3 }, { "color": "red", "value": 8 }] }
        }
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT name AS metric, execution_count AS value FROM soc_playbooks ORDER BY execution_count DESC",
        "format": "table", "refId": "A"
      }]
    },
    {
      "id": 11, "type": "table", "title": "Skill Registry",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "footer": { "show": false } },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "confidence_score" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "custom.width", "value": 130 },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "basic" } },
              { "id": "min", "value": 0 }, { "id": "max", "value": 1 },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.72 }, { "color": "green", "value": 0.85 }] } }
            ]
          },
          { "matcher": { "id": "byName", "options": "usage_count" },   "properties": [{ "id": "custom.width", "value": 80  }] },
          { "matcher": { "id": "byName", "options": "success_count" }, "properties": [{ "id": "custom.width", "value": 90  }] },
          { "matcher": { "id": "byName", "options": "decision" },      "properties": [{ "id": "custom.width", "value": 110 }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT skill_name, decision, confidence_score, usage_count, success_count, updated_at\nFROM soc_skills ORDER BY usage_count DESC",
        "format": "table", "refId": "A"
      }]
    },
    {
      "id": 12, "type": "table", "title": "Recent Playbook Executions",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "footer": { "show": false } },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "executed_at" },   "properties": [{ "id": "custom.width", "value": 180 }] },
          { "matcher": { "id": "byName", "options": "playbook_name" }, "properties": [{ "id": "custom.width", "value": 180 }] },
          { "matcher": { "id": "byName", "options": "case_id" },       "properties": [{ "id": "custom.width", "value": 130 }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT executed_at, case_id, playbook_name, actions_taken::text AS actions\nFROM soc_playbook_executions ORDER BY executed_at DESC LIMIT 30",
        "format": "table", "refId": "A"
      }]
    }
  ]
}
