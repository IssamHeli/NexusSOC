{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "NexusSoc PostgreSQL",
      "description": "NexusSoc ai_soc_results database",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",     "version": "10.0.0" },
    { "type": "datasource", "id": "postgres",   "name": "PostgreSQL",  "version": "1.0.0"  },
    { "type": "panel",      "id": "stat",       "name": "Stat",        "version": ""       },
    { "type": "panel",      "id": "timeseries", "name": "Time series", "version": ""       },
    { "type": "panel",      "id": "piechart",   "name": "Pie chart",   "version": ""       },
    { "type": "panel",      "id": "table",      "name": "Table",       "version": ""       }
  ],
  "annotations": { "list": [] },
  "description": "NexusSoc AI SOC — analysis volume, TP/FP rates, confidence trends",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nexussoc", "soc", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NexusSoc — SOC Overview",
  "uid": "nexussoc-overview-v1",
  "version": 1,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Total Analyses",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COUNT(*) AS value FROM ai_analysis", "format": "table", "refId": "A" }]
    },
    {
      "id": 2, "type": "stat", "title": "True Positives",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } } },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COUNT(*) AS value FROM ai_analysis WHERE ai_decision = 'True Positive'", "format": "table", "refId": "A" }]
    },
    {
      "id": 3, "type": "stat", "title": "False Positives",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COUNT(*) AS value FROM ai_analysis WHERE ai_decision = 'False Positive'", "format": "table", "refId": "A" }]
    },
    {
      "id": 4, "type": "stat", "title": "Avg Confidence",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.6 }, { "color": "green", "value": 0.8 }] }
        }
      },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT AVG(confidence) AS value FROM ai_analysis WHERE confidence IS NOT NULL", "format": "table", "refId": "A" }]
    },
    {
      "id": 5, "type": "stat", "title": "TP Rate",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 0.8 }] }
        }
      },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT CASE WHEN COUNT(*) = 0 THEN 0 ELSE COUNT(*) FILTER (WHERE ai_decision = 'True Positive')::float / COUNT(*) END AS value FROM ai_analysis", "format": "table", "refId": "A" }]
    },
    {
      "id": 6, "type": "stat", "title": "Analyses (24h)",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COUNT(*) AS value FROM ai_analysis WHERE timestamp >= NOW() - INTERVAL '24 hours'", "format": "table", "refId": "A" }]
    },
    {
      "id": 7, "type": "timeseries", "title": "Analyses Over Time — TP vs FP",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 9 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity", "showPoints": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "True Positives" },  "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red"   } }] },
          { "matcher": { "id": "byName", "options": "False Positives" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT\n  date_trunc('hour', timestamp) AS time,\n  COUNT(*) FILTER (WHERE ai_decision = 'True Positive')  AS \"True Positives\",\n  COUNT(*) FILTER (WHERE ai_decision = 'False Positive') AS \"False Positives\"\nFROM ai_analysis\nWHERE timestamp BETWEEN $__timeFrom() AND $__timeTo()\nGROUP BY 1 ORDER BY 1",
        "format": "time_series", "refId": "A"
      }]
    },
    {
      "id": 8, "type": "piechart", "title": "Decision Distribution",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 9 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["value", "percent"] } },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "True Positive" },  "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red"   } }] },
          { "matcher": { "id": "byName", "options": "False Positive" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }
        ]
      },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT ai_decision AS metric, COUNT(*) AS value FROM ai_analysis WHERE ai_decision IS NOT NULL GROUP BY ai_decision", "format": "table", "refId": "A" }]
    },
    {
      "id": 9, "type": "timeseries", "title": "Confidence Score Over Time",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Avg Confidence" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "cyan"   } }] },
          { "matcher": { "id": "byName", "options": "Max Confidence" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green"  } }] },
          { "matcher": { "id": "byName", "options": "Min Confidence" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT\n  date_trunc('hour', timestamp) AS time,\n  AVG(confidence) AS \"Avg Confidence\",\n  MAX(confidence) AS \"Max Confidence\",\n  MIN(confidence) AS \"Min Confidence\"\nFROM ai_analysis\nWHERE timestamp BETWEEN $__timeFrom() AND $__timeTo() AND confidence IS NOT NULL\nGROUP BY 1 ORDER BY 1",
        "format": "time_series", "refId": "A"
      }]
    },
    {
      "id": 10, "type": "timeseries", "title": "Analysis Volume per Hour",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "lineWidth": 0, "fillOpacity": 80, "drawStyle": "bars", "barAlignment": 0 }
        }
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT date_trunc('hour', timestamp) AS time, COUNT(*) AS \"Analyses\"\nFROM ai_analysis\nWHERE timestamp BETWEEN $__timeFrom() AND $__timeTo()\nGROUP BY 1 ORDER BY 1",
        "format": "time_series", "refId": "A"
      }]
    },
    {
      "id": 11, "type": "table", "title": "Recent Analyses",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 10 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "footer": { "show": false } },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "confidence" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "custom.width", "value": 120 },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "basic" } },
              { "id": "min", "value": 0 }, { "id": "max", "value": 1 }
            ]
          },
          { "matcher": { "id": "byName", "options": "timestamp" },   "properties": [{ "id": "custom.width", "value": 180 }] },
          { "matcher": { "id": "byName", "options": "case_id" },     "properties": [{ "id": "custom.width", "value": 140 }] },
          { "matcher": { "id": "byName", "options": "ai_decision" }, "properties": [{ "id": "custom.width", "value": 130 }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT\n  timestamp,\n  case_id,\n  ai_decision,\n  confidence,\n  recommended_action,\n  LEFT(analysis_summary, 120) AS summary\nFROM ai_analysis\nWHERE timestamp BETWEEN $__timeFrom() AND $__timeTo()\nORDER BY timestamp DESC LIMIT 50",
        "format": "table", "refId": "A"
      }]
    }
  ]
}
