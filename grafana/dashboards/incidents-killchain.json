{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "NexusSoc PostgreSQL",
      "description": "NexusSoc ai_soc_results database",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",     "version": "10.0.0" },
    { "type": "datasource", "id": "postgres",   "name": "PostgreSQL",  "version": "1.0.0"  },
    { "type": "panel",      "id": "stat",       "name": "Stat",        "version": ""       },
    { "type": "panel",      "id": "timeseries", "name": "Time series", "version": ""       },
    { "type": "panel",      "id": "piechart",   "name": "Pie chart",   "version": ""       },
    { "type": "panel",      "id": "bargauge",   "name": "Bar gauge",   "version": ""       },
    { "type": "panel",      "id": "table",      "name": "Table",       "version": ""       }
  ],
  "annotations": { "list": [] },
  "description": "NexusSoc — incident tracking, severity breakdown, kill chain phase coverage",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nexussoc", "incidents", "killchain"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NexusSoc — Incidents & Kill Chain",
  "uid": "nexussoc-incidents-v1",
  "version": 1,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Total Incidents",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COUNT(*) AS value FROM soc_incidents", "format": "table", "refId": "A" }]
    },
    {
      "id": 2, "type": "stat", "title": "Open Incidents",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 7 }] }
        }
      },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COUNT(*) AS value FROM soc_incidents WHERE status = 'open'", "format": "table", "refId": "A" }]
    },
    {
      "id": 3, "type": "stat", "title": "Critical Incidents",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COUNT(*) AS value FROM soc_incidents WHERE severity = 'critical'", "format": "table", "refId": "A" }]
    },
    {
      "id": 4, "type": "stat", "title": "Avg Cases / Incident",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 6 }] }
        }
      },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT AVG(case_count) AS value FROM soc_incidents", "format": "table", "refId": "A" }]
    },
    {
      "id": 5, "type": "stat", "title": "Unique ATT&CK Techniques",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } } },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COUNT(DISTINCT t) AS value FROM soc_incidents, unnest(mitre_techniques) AS t", "format": "table", "refId": "A" }]
    },
    {
      "id": 6, "type": "stat", "title": "High+ Severity",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "justifyMode": "center" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 2 }, { "color": "red", "value": 5 }] }
        }
      },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT COUNT(*) AS value FROM soc_incidents WHERE severity IN ('critical','high')", "format": "table", "refId": "A" }]
    },
    {
      "id": 7, "type": "timeseries", "title": "Incidents Created Over Time by Severity",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 9 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 0, "fillOpacity": 70, "drawStyle": "bars", "barAlignment": 0 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-red"    } }] },
          { "matcher": { "id": "byName", "options": "high" },     "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange"      } }] },
          { "matcher": { "id": "byName", "options": "medium" },   "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow"      } }] },
          { "matcher": { "id": "byName", "options": "low" },      "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "light-green" } }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT\n  date_trunc('hour', created_at) AS time,\n  COUNT(*) FILTER (WHERE severity = 'critical') AS critical,\n  COUNT(*) FILTER (WHERE severity = 'high')     AS high,\n  COUNT(*) FILTER (WHERE severity = 'medium')   AS medium,\n  COUNT(*) FILTER (WHERE severity = 'low')      AS low\nFROM soc_incidents\nWHERE created_at BETWEEN $__timeFrom() AND $__timeTo()\nGROUP BY 1 ORDER BY 1",
        "format": "time_series", "refId": "A"
      }]
    },
    {
      "id": 8, "type": "piechart", "title": "Incidents by Severity",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 9 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["value", "percent"] } },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-red"    } }] },
          { "matcher": { "id": "byName", "options": "high" },     "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange"      } }] },
          { "matcher": { "id": "byName", "options": "medium" },   "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow"      } }] },
          { "matcher": { "id": "byName", "options": "low" },      "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "light-green" } }] }
        ]
      },
      "targets": [{ "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" }, "rawSql": "SELECT severity AS metric, COUNT(*) AS value FROM soc_incidents GROUP BY severity", "format": "table", "refId": "A" }]
    },
    {
      "id": 9, "type": "bargauge", "title": "Kill Chain Phase Coverage",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlPu" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "purple", "value": 3 }, { "color": "red", "value": 6 }] }
        }
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT phase AS metric, COUNT(*) AS value\nFROM soc_incidents, unnest(kill_chain_phases) AS phase\nGROUP BY phase ORDER BY value DESC",
        "format": "table", "refId": "A"
      }]
    },
    {
      "id": 10, "type": "bargauge", "title": "Top MITRE ATT&CK Techniques",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-RdYlGr" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 2 }, { "color": "red", "value": 4 }] }
        }
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT technique AS metric, COUNT(*) AS value\nFROM soc_incidents, unnest(mitre_techniques) AS technique\nGROUP BY technique ORDER BY value DESC LIMIT 15",
        "format": "table", "refId": "A"
      }]
    },
    {
      "id": 11, "type": "table", "title": "Active Incidents",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 11 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "options": { "footer": { "show": false } },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "incident_id" }, "properties": [{ "id": "custom.width", "value": 150 }] },
          { "matcher": { "id": "byName", "options": "severity" },    "properties": [{ "id": "custom.width", "value": 90  }] },
          { "matcher": { "id": "byName", "options": "status" },      "properties": [{ "id": "custom.width", "value": 90  }] },
          { "matcher": { "id": "byName", "options": "case_count" },  "properties": [{ "id": "custom.width", "value": 80  }] },
          { "matcher": { "id": "byName", "options": "created_at" },  "properties": [{ "id": "custom.width", "value": 180 }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
        "rawSql": "SELECT\n  created_at,\n  incident_id,\n  severity,\n  status,\n  case_count,\n  array_to_string(kill_chain_phases, ' → ') AS kill_chain,\n  array_to_string(mitre_techniques,  ', ')  AS techniques,\n  array_to_string(attack_types,      ', ')  AS attack_types\nFROM soc_incidents\nORDER BY created_at DESC LIMIT 30",
        "format": "table", "refId": "A"
      }]
    }
  ]
}
