# ── Database (required) ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=soc_user
DB_PASS=changeme
DB_NAME=nexussoc

# ── Redis (optional — disables async /ingest if unset) ────────────────────────
REDIS_URL=redis://localhost:6379

# ── LLM router ────────────────────────────────────────────────────────────────
# Primary backend used for analysis. Options: ollama | openai | anthropic
LLM_BACKEND=ollama
# Comma-separated fallback chain tried in order if primary raises LLMError.
# Example: LLM_FALLBACK_CHAIN=openai,anthropic
LLM_FALLBACK_CHAIN=

# ── Ollama (local LLM, also used for embeddings — DO NOT swap embed model) ────
OLLAMA_HOST=host.docker.internal
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen3:1.7b
EMBED_MODEL=nomic-embed-text

# ── OpenAI backend (when LLM_BACKEND=openai or in fallback chain) ─────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Override base URL for Azure / proxy. Leave empty for api.openai.com.
OPENAI_BASE_URL=

# ── Anthropic backend (when LLM_BACKEND=anthropic or in fallback chain) ───────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=2048

# ── Plugins — Notification ────────────────────────────────────────────────────
# Discord: enabled by default. Set PLUGIN_DISCORD_ENABLED=false to disable.
PLUGIN_DISCORD_ENABLED=true
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_id/your_token

# Slack: disabled by default. Set PLUGIN_SLACK_ENABLED=true + SLACK_WEBHOOK to enable.
PLUGIN_SLACK_ENABLED=false
SLACK_WEBHOOK=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXX

# Microsoft Teams: disabled by default. Set PLUGIN_TEAMS_ENABLED=true + TEAMS_WEBHOOK to enable.
PLUGIN_TEAMS_ENABLED=false
TEAMS_WEBHOOK=https://your-org.webhook.office.com/webhookb2/your-teams-webhook

# ── Plugins — Enrichment ──────────────────────────────────────────────────────
# VirusTotal: disabled by default. Set PLUGIN_VT_ENABLED=true + VT_API_KEY to enable.
PLUGIN_VT_ENABLED=false
VT_API_KEY=

# AbuseIPDB: disabled by default. Set PLUGIN_ABUSEIPDB_ENABLED=true + ABUSEIPDB_API_KEY to enable.
PLUGIN_ABUSEIPDB_ENABLED=false
ABUSEIPDB_API_KEY=

# ── Plugins — Export ──────────────────────────────────────────────────────────
# MITRE ATT&CK Navigator: enabled by default.
PLUGIN_MITRE_EXPORT_ENABLED=true

# STIX 2.1 export: disabled by default (stub — full implementation pending).
PLUGIN_STIX2_ENABLED=false

# ── Playbooks ─────────────────────────────────────────────────────────────────
# Set to false to execute real webhook actions (block IPs, quarantine endpoints)
PLAYBOOK_DRY_RUN=true

# ── Authentication (V2) ───────────────────────────────────────────────────────
# false = no auth (local dev). true = JWT enforced on all endpoints (prod)
AUTH_ENABLED=false

# Required when AUTH_ENABLED=true — min 32 random characters
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_random_32_char_secret_here

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Initial admin account created on first startup (only if ADMIN_PASSWORD is set)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Internal API key for worker → API machine-to-machine calls
# Generate: python3 -c "import secrets; print(secrets.token_hex(24))"
API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Never use * in production.
CORS_ORIGINS=http://localhost:5173

# ── HTTPS ─────────────────────────────────────────────────────────────────────
# true = add Strict-Transport-Security header (only when behind TLS termination)
HTTPS_ONLY=false
